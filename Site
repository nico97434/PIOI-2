<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PIOI — Plateforme Investissement Outre-Mer Immobilier</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #c8a96e;
  --gold-light: #e8d09a;
  --gold-dark: #9a7a42;
  --obsidian: #0b0d11;
  --surface: #111318;
  --surface2: #181b22;
  --surface3: #1e222b;
  --border: rgba(200,169,110,0.15);
  --border-soft: rgba(255,255,255,0.06);
  --text: #f0ece4;
  --text-muted: rgba(240,236,228,0.5);
  --text-dim: rgba(240,236,228,0.28);
  --green: #5fa882;
  --green-bg: rgba(95,168,130,0.12);
  --red: #c0604a;
  --red-bg: rgba(192,96,74,0.12);
  --blue: #5b8fc4;
  --blue-bg: rgba(91,143,196,0.12);
  --amber: #c8a030;
  --amber-bg: rgba(200,160,48,0.12);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--obsidian);color:var(--text);font-family:'Outfit',sans-serif;font-size:14px;line-height:1.6;overflow-x:hidden}
::selection{background:rgba(200,169,110,0.3);color:#fff}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--surface)}
::-webkit-scrollbar-thumb{background:var(--gold-dark);border-radius:3px}
 
/* ─── COVER ─── */
#cover {
  position:fixed;inset:0;z-index:1000;
  background:var(--obsidian);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  transition:opacity .8s ease, visibility .8s ease;
}
#cover.gone{opacity:0;visibility:hidden;pointer-events:none}
.cover-bg {
  position:absolute;inset:0;overflow:hidden;
}
.cover-line {
  position:absolute;border:1px solid rgba(200,169,110,0.08);border-radius:50%;
  transform:translate(-50%,-50%);left:50%;top:50%;
  animation:pulse-ring 6s ease-in-out infinite;
}
.cover-line:nth-child(1){width:320px;height:320px;animation-delay:0s}
.cover-line:nth-child(2){width:520px;height:520px;animation-delay:.8s}
.cover-line:nth-child(3){width:720px;height:720px;animation-delay:1.6s}
.cover-line:nth-child(4){width:980px;height:980px;animation-delay:2.4s}
@keyframes pulse-ring{0%,100%{opacity:.3;transform:translate(-50%,-50%) scale(1)}50%{opacity:.7;transform:translate(-50%,-50%) scale(1.015)}}
.cover-dots {
  position:absolute;inset:0;
  background-image:radial-gradient(circle, rgba(200,169,110,0.12) 1px, transparent 1px);
  background-size:40px 40px;
  mask-image:radial-gradient(ellipse 70% 70% at 50% 50%, black 30%, transparent 100%);
}
.cover-glow{
  position:absolute;width:400px;height:400px;
  background:radial-gradient(circle, rgba(200,169,110,0.06) 0%, transparent 70%);
  left:50%;top:50%;transform:translate(-50%,-50%);
  animation:glow-pulse 4s ease-in-out infinite;
}
@keyframes glow-pulse{0%,100%{opacity:.6}50%{opacity:1}}
.cover-content{position:relative;z-index:2;text-align:center}
.logo-mark{
  display:inline-flex;align-items:center;justify-content:center;
  width:72px;height:72px;border:1.5px solid var(--gold);border-radius:50%;
  margin-bottom:28px;
  animation:logo-spin 20s linear infinite;
  position:relative;
}
.logo-mark::before{
  content:'';position:absolute;inset:6px;border-radius:50%;
  border:0.5px solid rgba(200,169,110,0.3);
}
.logo-mark svg{width:36px;height:36px}
@keyframes logo-spin{to{transform:rotate(360deg)}}
.cover-pioi{
  font-family:'Cormorant Garamond',serif;font-size:clamp(72px,12vw,128px);
  font-weight:300;letter-spacing:.25em;color:var(--text);
  line-height:1;margin-bottom:8px;
  animation:fade-up .8s ease both;
}
.cover-pioi span{color:var(--gold)}
.cover-tagline{
  font-size:11px;letter-spacing:.35em;text-transform:uppercase;
  color:var(--text-muted);margin-bottom:52px;
  animation:fade-up .8s .15s ease both;
}
.cover-sub{
  font-family:'Cormorant Garamond',serif;font-size:16px;font-style:italic;
  color:var(--gold);letter-spacing:.08em;margin-bottom:52px;
  animation:fade-up .8s .25s ease both;
}
.cover-line-h{
  width:1px;height:48px;background:linear-gradient(to bottom,transparent,var(--gold),transparent);
  margin:0 auto 24px;
  animation:fade-up .8s .35s ease both;
}
.enter-btn{
  padding:14px 48px;border:1px solid var(--gold);background:transparent;
  color:var(--gold);font-family:'Outfit',sans-serif;font-size:12px;
  letter-spacing:.2em;text-transform:uppercase;cursor:pointer;
  transition:all .3s ease;
  animation:fade-up .8s .45s ease both;
  position:relative;overflow:hidden;
}
.enter-btn::before{
  content:'';position:absolute;inset:0;background:var(--gold);
  transform:translateY(100%);transition:transform .3s ease;z-index:-1;
}
.enter-btn:hover{color:var(--obsidian)}
.enter-btn:hover::before{transform:translateY(0)}
.cover-version{
  position:absolute;bottom:28px;left:50%;transform:translateX(-50%);
  font-size:11px;letter-spacing:.15em;color:var(--text-dim);text-transform:uppercase;
}
@keyframes fade-up{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
 
/* ─── APP ─── */
#app{min-height:100vh;opacity:0;transition:opacity .6s ease}
#app.visible{opacity:1}
 
/* Navbar */
nav{
  position:sticky;top:0;z-index:100;
  background:rgba(11,13,17,0.92);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border-soft);
  padding:0 32px;height:60px;display:flex;align-items:center;justify-content:space-between;
}
.nav-brand{display:flex;align-items:center;gap:12px}
.nav-logo-box{
  width:36px;height:36px;border:1px solid var(--gold);
  display:flex;align-items:center;justify-content:center;
  position:relative;
}
.nav-logo-box::before{
  content:'';position:absolute;inset:4px;
  border:0.5px solid rgba(200,169,110,0.3);
}
.nav-pioi{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:400;letter-spacing:.2em;color:var(--text)}
.nav-pioi span{color:var(--gold)}
.nav-subtitle{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:var(--text-dim)}
.nav-badge{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);
  border:1px solid var(--border);padding:3px 12px;background:rgba(200,169,110,0.05)}
 
/* Main */
main{max-width:1100px;margin:0 auto;padding:40px 32px 80px}
 
/* Section title */
.sec-hd{display:flex;align-items:center;gap:16px;margin-bottom:24px}
.sec-hd-line{flex:1;height:1px;background:var(--border-soft)}
.sec-hd-title{font-family:'Cormorant Garamond',serif;font-size:13px;font-weight:400;
  letter-spacing:.25em;text-transform:uppercase;color:var(--gold);white-space:nowrap}
 
/* Tabs */
.tabs-bar{display:flex;gap:2px;background:var(--surface2);padding:4px;border-radius:4px;margin-bottom:32px;overflow-x:auto}
.tab-btn{flex:1;min-width:0;padding:9px 14px;background:none;border:none;cursor:pointer;
  font-family:'Outfit',sans-serif;font-size:12px;letter-spacing:.06em;text-transform:uppercase;
  color:var(--text-muted);white-space:nowrap;transition:all .2s;border-radius:3px}
.tab-btn:hover{color:var(--text);background:rgba(255,255,255,0.04)}
.tab-btn.active{background:var(--surface3);color:var(--gold);font-weight:500}
.tab-content{display:none}
.tab-content.active{display:block;animation:fade-up .3s ease both}
 
/* Cards */
.card{background:var(--surface);border:1px solid var(--border-soft);border-radius:4px;padding:24px}
.card-gold{background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:24px}
.metric-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:20px}
.metric{background:var(--surface2);border-radius:4px;padding:16px}
.metric-lbl{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--text-dim);margin-bottom:8px}
.metric-val{font-size:22px;font-weight:500;line-height:1}
.metric-val.gold{color:var(--gold)}
.metric-val.green{color:var(--green)}
.metric-val.red{color:var(--red)}
.metric-val.blue{color:var(--blue)}
.metric-val.amber{color:var(--amber)}
.metric-sub{font-size:11px;color:var(--text-dim);margin-top:4px}
 
/* Form grid */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px 24px}
.form-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px 20px}
.form-group{display:flex;flex-direction:column;gap:6px}
.form-label{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--text-muted)}
.input-wrap{display:flex;align-items:center;background:var(--surface2);border:1px solid var(--border-soft);border-radius:3px;overflow:hidden;transition:border-color .2s}
.input-wrap:focus-within{border-color:rgba(200,169,110,0.4)}
.input-wrap input{flex:1;background:none;border:none;outline:none;padding:9px 12px;color:var(--text);font-family:'Outfit',sans-serif;font-size:13px;min-width:0}
.input-wrap input::placeholder{color:var(--text-dim)}
.input-suffix{padding:0 12px;font-size:12px;color:var(--text-dim);white-space:nowrap;border-left:1px solid var(--border-soft);background:rgba(255,255,255,0.02)}
.input-wrap select{flex:1;background:none;border:none;outline:none;padding:9px 12px;color:var(--text);font-family:'Outfit',sans-serif;font-size:13px;-webkit-appearance:none}
.input-wrap select option{background:var(--surface2)}
 
/* Toggle pills */
.pill-group{display:flex;flex-wrap:wrap;gap:6px;margin-top:4px}
.pill{padding:5px 14px;border:1px solid var(--border-soft);border-radius:20px;font-size:11px;
  letter-spacing:.06em;cursor:pointer;background:none;color:var(--text-muted);transition:all .2s}
.pill:hover{border-color:var(--border);color:var(--text)}
.pill.active{background:rgba(200,169,110,0.12);border-color:var(--gold);color:var(--gold)}
 
/* Checkbox */
.check-row{display:flex;align-items:center;gap:10px;cursor:pointer;padding:8px 0}
.check-row input[type=checkbox]{width:15px;height:15px;accent-color:var(--gold);cursor:pointer}
.check-row span{font-size:12px;color:var(--text-muted)}
 
/* Table */
.data-table{width:100%;border-collapse:collapse;font-size:13px}
.data-table th{text-align:left;padding:8px 12px;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--text-dim);font-weight:400;border-bottom:1px solid var(--border-soft)}
.data-table td{padding:9px 12px;border-bottom:1px solid rgba(255,255,255,0.03)}
.data-table tr:last-child td{border-bottom:none}
.data-table tr:hover td{background:rgba(255,255,255,0.02)}
.data-table td.right{text-align:right}
.data-table td.green{color:var(--green);font-weight:500}
.data-table td.red{color:var(--red)}
.data-table td.gold{color:var(--gold);font-weight:500}
 
/* Row divider */
.kv{display:flex;justify-content:space-between;align-items:baseline;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04);font-size:13px}
.kv:last-child{border-bottom:none}
.kv-k{color:var(--text-muted)}
.kv-v{font-weight:500}
.kv-v.hl{color:var(--gold)}
.kv-v.green{color:var(--green)}
.kv-v.red{color:var(--red)}
 
/* Info box */
.info-box{background:rgba(200,169,110,0.05);border-left:2px solid var(--gold);padding:12px 16px;font-size:12px;color:var(--text-muted);line-height:1.7;margin-bottom:24px;letter-spacing:.01em}
.info-box strong{color:var(--gold)}
 
/* Bar charts */
.bar-chart-row{display:flex;align-items:center;gap:12px;margin-bottom:8px;font-size:12px}
.bar-chart-lbl{width:120px;text-align:right;color:var(--text-muted);flex-shrink:0}
.bar-chart-bar{height:18px;border-radius:2px;transition:width .5s ease;min-width:2px}
.bar-chart-num{color:var(--text);font-weight:500;min-width:80px}
 
/* Progress bar */
.progress-wrap{background:rgba(255,255,255,0.06);border-radius:2px;height:5px;overflow:hidden}
.progress-fill{height:100%;border-radius:2px;transition:width .5s ease}
 
/* Badge */
.badge{display:inline-flex;align-items:center;font-size:11px;letter-spacing:.06em;padding:3px 10px;border-radius:2px;font-weight:500}
.badge-gold{background:rgba(200,169,110,0.12);color:var(--gold);border:1px solid rgba(200,169,110,0.2)}
.badge-green{background:var(--green-bg);color:var(--green)}
.badge-red{background:var(--red-bg);color:var(--red)}
.badge-blue{background:var(--blue-bg);color:var(--blue)}
.badge-amber{background:var(--amber-bg);color:var(--amber)}
 
/* Divider */
hr.div{border:none;border-top:1px solid var(--border-soft);margin:20px 0}
 
/* Score ring */
.ring-wrap{display:flex;flex-direction:column;align-items:center;gap:8px}
.ring-label{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--text-dim);text-align:center;max-width:80px}
.scores-row{display:flex;gap:24px;flex-wrap:wrap;justify-content:center;padding:20px 0}
 
/* Transition indicator */
.sep-deco{display:flex;align-items:center;gap:12px;margin:28px 0}
.sep-deco::before,.sep-deco::after{content:'';flex:1;height:1px;background:var(--border-soft)}
.sep-deco-icon{width:6px;height:6px;background:var(--gold);transform:rotate(45deg);flex-shrink:0}
 
/* Cover for annonce analyzer */
.hero-text{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,4vw,42px);font-weight:300;
  line-height:1.2;margin-bottom:8px;letter-spacing:-.01em}
.hero-text em{color:var(--gold);font-style:italic}
 
/* Responsive */
@media(max-width:680px){
  .form-grid,.form-grid-3{grid-template-columns:1fr}
  main{padding:24px 16px 60px}
  nav{padding:0 16px}
}
 
/* Welcome screen inside app */
#welcome{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  min-height:60vh;text-align:center;padding:40px 20px;
}
.welcome-divider{width:1px;height:60px;background:linear-gradient(to bottom,transparent,var(--gold),transparent);margin:32px auto}
 
/* Two-column layout for bilan */
.bilan-grid{display:grid;grid-template-columns:2fr 1fr;gap:24px}
@media(max-width:820px){.bilan-grid{grid-template-columns:1fr}}
</style>
</head>
<body>
 
<!-- ═══ COVER PAGE ═══ -->
<div id="cover">
  <div class="cover-bg">
    <div class="cover-dots"></div>
    <div class="cover-glow"></div>
    <div class="cover-line"></div>
    <div class="cover-line"></div>
    <div class="cover-line"></div>
    <div class="cover-line"></div>
  </div>
  <div class="cover-content">
    <div class="logo-mark">
      <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="18,4 32,28 4,28" stroke="#c8a96e" stroke-width="1" fill="none"/>
        <polygon points="18,10 27,26 9,26" stroke="rgba(200,169,110,0.35)" stroke-width="0.5" fill="none"/>
        <circle cx="18" cy="18" r="2" fill="#c8a96e"/>
      </svg>
    </div>
    <div class="cover-pioi">P<span>I</span>OI</div>
    <div class="cover-tagline">Plateforme Investissement Outre-Mer Immobilier</div>
    <div class="cover-sub">Analyse · Défiscalisation · Rentabilité</div>
    <div class="cover-line-h"></div>
    <button class="enter-btn" onclick="enterApp()">Accéder à la plateforme</button>
  </div>
  <div class="cover-version">Version 2.0 · La Réunion · © PIOI 2026</div>
</div>
 
<!-- ═══ APP ═══ -->
<div id="app">
  <nav>
    <div class="nav-brand">
      <div class="nav-logo-box">
        <svg width="18" height="18" viewBox="0 0 36 36" fill="none">
          <polygon points="18,4 32,28 4,28" stroke="#c8a96e" stroke-width="1.5" fill="none"/>
          <circle cx="18" cy="18" r="2" fill="#c8a96e"/>
        </svg>
      </div>
      <div>
        <div class="nav-pioi">P<span>I</span>OI</div>
        <div class="nav-subtitle">Investissement Outre-Mer</div>
      </div>
    </div>
    <div class="nav-badge">CIOP Touristique</div>
  </nav>
 
  <main>
    <!-- Welcome -->
    <div id="welcome">
      <div class="hero-text">Simulateur <em>CIOP Touristique</em></div>
      <div class="hero-text" style="font-size:clamp(15px,2vw,20px);color:var(--text-muted)">Location saisonnière · Défiscalisation · La Réunion</div>
      <div class="welcome-divider"></div>
      <p style="color:var(--text-muted);font-size:13px;max-width:480px;line-height:1.8">
        Entrez vos paramètres dans chaque onglet pour obtenir une analyse complète de votre investissement immobilier touristique en Outre-Mer, incluant le calcul du Crédit d'Impôt (LODEOM), la rentabilité locative saisonnière et une projection financière sur 10 ans.
      </p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:28px">
        <span class="badge badge-gold">LODEOM / CIOP</span>
        <span class="badge badge-blue">Location saisonnière</span>
        <span class="badge badge-green">Bilan 10 ans</span>
        <span class="badge badge-amber">LMNP Réel</span>
      </div>
    </div>
 
    <!-- Tabs -->
    <div class="sec-hd"><div class="sec-hd-line"></div><div class="sec-hd-title">Paramètres & Simulation</div><div class="sec-hd-line"></div></div>
    <div class="tabs-bar">
      <button class="tab-btn active" data-tab="0">① Investissement</button>
      <button class="tab-btn" data-tab="1">② Défiscalisation</button>
      <button class="tab-btn" data-tab="2">③ Revenus</button>
      <button class="tab-btn" data-tab="3">④ Charges</button>
      <button class="tab-btn" data-tab="4">⑤ Financement</button>
      <button class="tab-btn" data-tab="5">⑥ Bilan</button>
    </div>
 
    <!-- ① INVESTISSEMENT -->
    <div class="tab-content active" id="tab-0">
      <div class="info-box"><strong>Note :</strong> Le terrain est exclu de l'assiette CIOP. Renseignez les montants hors taxes — la TVA de 8,5 % sera calculée automatiquement si vous n'êtes pas assujetti.</div>
      <div class="card" style="margin-bottom:20px">
        <div class="form-grid">
          <div class="form-group"><label class="form-label">Coût du terrain</label><div class="input-wrap"><input type="number" id="i_terrain" value="80000" step="1000"><span class="input-suffix">€</span></div></div>
          <div class="form-group"><label class="form-label">Coût de construction HT</label><div class="input-wrap"><input type="number" id="i_construction" value="250000" step="1000"><span class="input-suffix">€</span></div></div>
          <div class="form-group"><label class="form-label">Équipements & mobilier HT</label><div class="input-wrap"><input type="number" id="i_equipements" value="35000" step="500"><span class="input-suffix">€</span></div></div>
          <div class="form-group"><label class="form-label">Honoraires architecte / MOE</label><div class="input-wrap"><input type="number" id="i_honoraires_pct" value="8" step="0.5" min="0" max="20"><span class="input-suffix">%</span></div></div>
          <div class="form-group"><label class="form-label">Frais notaire & géomètre</label><div class="input-wrap"><input type="number" id="i_notaire" value="5000" step="100"><span class="input-suffix">€</span></div></div>
          <div class="form-group"><label class="form-label">Autres (permis, VRD, divers)</label><div class="input-wrap"><input type="number" id="i_autres" value="5000" step="100"><span class="input-suffix">€</span></div></div>
        </div>
        <label class="check-row" style="margin-top:16px">
          <input type="checkbox" id="i_tva_recup">
          <span>TVA récupérable — Investisseur assujetti à la TVA (TVA 8,5 % non applicable)</span>
        </label>
      </div>
      <div class="card-gold">
        <div style="font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:16px">Récapitulatif investissement</div>
        <div class="kv"><span class="kv-k">Construction + équipements HT</span><span class="kv-v" id="r_const_equip">—</span></div>
        <div class="kv"><span class="kv-k">Honoraires <span id="r_hon_pct"></span></span><span class="kv-v" id="r_honores">—</span></div>
        <div class="kv"><span class="kv-k">Terrain</span><span class="kv-v" id="r_terrain">—</span></div>
        <div class="kv"><span class="kv-k">Frais & divers</span><span class="kv-v" id="r_frais">—</span></div>
        <div class="kv" id="tva_row"><span class="kv-k">TVA 8,5 % (construction)</span><span class="kv-v" id="r_tva">—</span></div>
        <div class="kv" style="border-top:1px solid var(--border);padding-top:12px;margin-top:4px">
          <span class="kv-k" style="font-weight:500;font-size:14px">Investissement total</span>
          <span class="kv-v hl" style="font-size:18px" id="r_total_ttc">—</span>
        </div>
      </div>
    </div>
 
    <!-- ② DÉFISCALISATION -->
    <div class="tab-content" id="tab-1">
      <div class="info-box">
        <strong>CIOP Touristique (LODEOM)</strong> — Crédit d'impôt sur investissements productifs dans le secteur touristique en DOM. Taux standard : 30,6 % | Taux bonifié secteur prioritaire : 35,85 % | Maximum avec cumul d'avantages : 40,85 %.
      </div>
      <div class="card" style="margin-bottom:20px">
