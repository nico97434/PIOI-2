<script>
// ─── Utils ─────────────────────────────────────────────────────────────────
const fmt = (n,d=0) => isNaN(n) ? '—' : new Intl.NumberFormat('fr-FR',{maximumFractionDigits:d,minimumFractionDigits:d}).format(Math.round(n*Math.pow(10,d))/Math.pow(10,d));
const fmtE = (n,d=0) => fmt(n,d) + ' €';
const fmtP = (n,d=1) => fmt(n,d) + ' %';
const pct = (a,b) => b ? Math.round(a/b*1000)/10 : 0;
const el = id => document.getElementById(id);
const val = id => parseFloat(el(id).value) || 0;
const chk = id => el(id).checked;
 
// ─── Cover ─────────────────────────────────────────────────────────────────
function enterApp() {
  el('cover').classList.add('gone');
  el('app').classList.add('visible');
  setTimeout(compute, 100);
}
 
// ─── Pill groups ───────────────────────────────────────────────────────────
let state = { assiette_mode:'auto', taux_mode:'35.85' };
 
document.querySelectorAll('.pill[data-group]').forEach(b => {
  b.addEventListener('click', function() {
    const g = this.dataset.group;
    document.querySelectorAll(`.pill[data-group="${g}"]`).forEach(p=>p.classList.remove('active'));
    this.classList.add('active');
    state[g+'_mode'] = this.dataset.val;
    if(g==='assiette') {
      el('assiette_auto_info').style.display = this.dataset.val==='auto'?'block':'none';
      el('assiette_custom_wrap').style.display = this.dataset.val==='custom'?'block':'none';
    }
    if(g==='taux') {
      el('taux_custom_wrap').style.display = this.dataset.val==='custom'?'block':'none';
    }
    compute();
  });
});
 
// ─── Tabs ──────────────────────────────────────────────────────────────────
document.querySelectorAll('.tab-btn').forEach(b => {
  b.addEventListener('click', function() {
    document.querySelectorAll('.tab-btn').forEach(x=>x.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(x=>x.classList.remove('active'));
    this.classList.add('active');
    el('tab-'+this.dataset.tab).classList.add('active');
    if(this.dataset.tab==='5') compute();
  });
});
 
// ─── All inputs → compute ─────────────────────────────────────────────────
document.querySelectorAll('input,select').forEach(i => i.addEventListener('input', compute));
 
// ─── Main compute ─────────────────────────────────────────────────────────
function compute() {
  // Investissement
  const terrain = val('i_terrain');
  const constr = val('i_construction');
  const equip = val('i_equipements');
  const hon_pct = val('i_honoraires_pct');
  const notaire = val('i_notaire');
  const autres_inv = val('i_autres');
  const tva_recup = chk('i_tva_recup');
  const honores = (constr + equip) * hon_pct / 100;
  const tva = tva_recup ? 0 : (constr + equip) * 0.085;
  const total_ttc = terrain + constr + equip + honores + notaire + autres_inv + tva;
 
  // Défiscalisation
  const assiette_auto = constr + equip + honores;
  const assiette = state.assiette_mode==='custom' ? val('d_assiette_custom') : assiette_auto;
  let taux_base = state.taux_mode==='custom' ? val('d_taux_custom') : parseFloat(state.taux_mode);
  const bonif = chk('d_bonification');
  const taux_eff = taux_base + (bonif ? 5 : 0);
  const part = val('d_part_invest') / 100;
  const etalement = val('d_etalement') || 5;
  const ci_total = assiette * taux_eff / 100;
  const ci_invest = ci_total * part;
  const ci_annuel = ci_invest / etalement;
  const cout_reel = total_ttc - ci_invest;
 
  // Revenus
  const tarif_hs = val('r_tarif_hs'), sem_hs = val('r_sem_hs'), occ_hs = val('r_occ_hs');
  const tarif_bs = val('r_tarif_bs'), sem_bs = val('r_sem_bs'), occ_bs = val('r_occ_bs');
  const comm_pct = val('r_commission'), menage = val('r_menage');
  const duree = val('r_duree') || 4, taxe_sej = val('r_taxe_sej');
  const nuits_hs = Math.round(sem_hs * 7 * occ_hs / 100);
  const nuits_bs = Math.round(sem_bs * 7 * occ_bs / 100);
  const total_nuits = nuits_hs + nuits_bs;
  const total_nuits_dispo = (sem_hs + sem_bs) * 7;
  const taux_occ = pct(total_nuits, total_nuits_dispo);
  const rev_hs = nuits_hs * tarif_hs;
  const rev_bs = nuits_bs * tarif_bs;
  const rev_brut = rev_hs + rev_bs;
  const nb_sejours = Math.round(total_nuits / duree);
  const comm_mont = rev_brut * comm_pct / 100;
  const menages_mont = nb_sejours * menage;
  const taxe_sej_mont = total_nuits * taxe_sej;
  const rev_net = rev_brut - comm_mont - menages_mont - taxe_sej_mont;
 
  // Charges
  const c_fonciere = val('c_fonciere'), c_assurance = val('c_assurance');
  const c_energie = val('c_energie'), c_entretien = val('c_entretien');
  const c_conciergerie = val('c_conciergerie'), c_comptable = val('c_comptable');
  const c_cfe = val('c_cfe'), c_autres = val('c_autres');
  const chg_total = c_fonciere+c_assurance+c_energie+c_entretien+c_conciergerie+c_comptable+c_cfe+c_autres;
 
  // Financement
  const apport_pct = val('f_apport_pct')/100;
  const taux_credit = val('f_taux')/100/12;
  const duree_credit = val('f_duree')*12;
  const emprunt = total_ttc * (1 - apport_pct);
  const apport = total_ttc * apport_pct;
  const mensualite = emprunt>0&&taux_credit>0 ? emprunt*taux_credit*Math.pow(1+taux_credit,duree_credit)/(Math.pow(1+taux_credit,duree_credit)-1) : 0;
  const total_interets = mensualite*duree_credit - emprunt;
 
  // Bilan
  const resultat = rev_net - chg_total;
  const cf_mensuel = resultat / 12;
  const rdt_brut = pct(rev_brut, total_ttc);
  const rdt_net = pct(rev_net - chg_total, total_ttc);
  const rdt_ajuste = cout_reel > 0 ? pct(rev_net - chg_total + ci_annuel, cout_reel) : 0;
  const payback = cout_reel>0&&resultat+ci_annuel>0 ? cout_reel/(resultat+ci_annuel) : null;
 
  // ─── Render Tab 0 ────
  if(el('r_const_equip')) {
    el('r_const_equip').textContent = fmtE(constr+equip);
    el('r_hon_pct').textContent = `(${hon_pct}%)`;
    el('r_honores').textContent = fmtE(honores);
    el('r_terrain').textContent = fmtE(terrain);
    el('r_frais').textContent = fmtE(notaire+autres_inv);
    el('r_tva').textContent = fmtE(tva);
    el('tva_row').style.display = tva_recup ? 'none' : 'flex';
    el('r_total_ttc').textContent = fmtE(total_ttc);
    el('assiette_auto_info').innerHTML = `= Construction + équipements + honoraires = <strong style="color:var(--gold)">${fmtE(assiette_auto)}</strong>`;
  }
 
  // ─── Render Tab 1 ────
  const dm = el('defisc_metrics');
  if(dm) dm.innerHTML = `
    <div class="metric"><div class="metric-lbl">Assiette défiscalisable</div><div class="metric-val blue">${fmtE(assiette)}</div></div>
    <div class="metric"><div class="metric-lbl">Taux effectif</div><div class="metric-val blue">${fmtP(taux_eff)}</div></div>
    <div class="metric"><div class="metric-lbl">Crédit d'impôt total</div><div class="metric-val green">${fmtE(ci_total)}</div></div>
    <div class="metric"><div class="metric-lbl">Part investisseur (${val('d_part_invest')}%)</div><div class="metric-val green">${fmtE(ci_invest)}</div></div>
    <div class="metric"><div class="metric-lbl">Économie / an (${etalement} ans)</div><div class="metric-val green">${fmtE(ci_annuel)}</div></div>
    <div class="metric"><div class="metric-lbl">Coût réel après CIOP</div><div class="metric-val amber">${fmtE(cout_reel)}</div></div>`;
  if(el('ciop_bar')) {
    const p = Math.min(100, pct(ci_invest, total_ttc));
    el('ciop_bar').style.width = p+'%';
    el('cout_reel_label').textContent = fmtE(cout_reel);
    el('economie_pct_label').textContent = `Économie : ${fmtP(pct(ci_invest,total_ttc))}`;
    el('total_ttc_label2').textContent = fmtE(total_ttc);
  }
 
  // ─── Render Tab 2 ────
  const rm = el('rev_metrics');
  if(rm) rm.innerHTML = `
    <div class="metric"><div class="metric-lbl">Nuits HS / BS</div><div class="metric-val">${nuits_hs} / ${nuits_bs}</div></div>
    <div class="metric"><div class="metric-lbl">Total nuits louées</div><div class="metric-val blue">${total_nuits}</div></div>
    <div class="metric"><div class="metric-lbl">Taux occupation global</div><div class="metric-val ${taux_occ>=60?'green':taux_occ>=40?'amber':'red'}">${fmtP(taux_occ)}</div></div>
    <div class="metric"><div class="metric-lbl">Revenus bruts HS</div><div class="metric-val">${fmtE(rev_hs)}</div></div>
    <div class="metric"><div class="metric-lbl">Revenus bruts BS</div><div class="metric-val">${fmtE(rev_bs)}</div></div>
    <div class="metric"><div class="metric-lbl">Revenus bruts annuels</div><div class="metric-val green">${fmtE(rev_brut)}</div></div>`;
  const rd = el('rev_detail');
  if(rd) rd.innerHTML = `
    <div style="font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:16px">Décomposition revenus</div>
    <div class="kv"><span class="kv-k">Revenus bruts</span><span class="kv-v">${fmtE(rev_brut)}</span></div>
    <div class="kv"><span class="kv-k">– Commission plateforme (${comm_pct}%)</span><span class="kv-v red">– ${fmtE(comm_mont)}</span></div>
    <div class="kv"><span class="kv-k">– Frais ménage (${nb_sejours} séjours × ${menage}€)</span><span class="kv-v red">– ${fmtE(menages_mont)}</span></div>
    <div class="kv"><span class="kv-k">– Taxe de séjour (${total_nuits} nuits × ${taxe_sej}€)</span><span class="kv-v red">– ${fmtE(taxe_sej_mont)}</span></div>
    <div class="kv" style="border-top:1px solid var(--border);padding-top:12px;margin-top:4px"><span class="kv-k" style="font-size:14px;font-weight:500">Revenus nets d'exploitation</span><span class="kv-v hl" style="font-size:17px">${fmtE(rev_net)}</span></div>`;
 
  // ─── Render Tab 3 ────
  const charges = [
    ['Taxe foncière', c_fonciere],['Assurance', c_assurance],
    ['Eau & électricité', c_energie],['Entretien', c_entretien],
    ['Conciergerie', c_conciergerie],['Comptable', c_comptable],
    ['CFE & cotisations', c_cfe],['Autres', c_autres]
  ].filter(([,v])=>v>0);
  const cc = el('charges_chart');
  if(cc) cc.innerHTML = charges.map(([l,v])=>`
    <div class="bar-chart-row">
      <span class="bar-chart-lbl">${l}</span>
      <div class="bar-chart-bar" style="width:${chg_total>0?Math.round(v/chg_total*220):0}px;background:var(--red);opacity:.7"></div>
      <span class="bar-chart-num">${fmtE(v)}</span>
    </div>`).join('');
  if(el('r_chg_total')) el('r_chg_total').textContent = fmtE(chg_total);
 
  // ─── Render Tab 4 ────
  const credm = el('credit_metrics');
  if(credm) credm.innerHTML = `
    <div class="metric"><div class="metric-lbl">Apport personnel</div><div class="metric-val">${fmtE(apport)}</div></div>
    <div class="metric"><div class="metric-lbl">Montant emprunté</div><div class="metric-val blue">${fmtE(emprunt)}</div></div>
    <div class="metric"><div class="metric-lbl">Mensualité estimée</div><div class="metric-val amber">${fmtE(mensualite)}/mois</div></div>
    <div class="metric"><div class="metric-lbl">Coût total intérêts</div><div class="metric-val red">${fmtE(total_interets)}</div></div>
    <div class="metric"><div class="metric-lbl">Charge crédit annuelle</div><div class="metric-val red">${fmtE(mensualite*12)}</div></div>
    <div class="metric"><div class="metric-lbl">Coût total crédit</div><div class="metric-val">${fmtE(mensualite*duree_credit)}</div></div>`;
 
  // ─── Render Tab 5 ────
  const bmt = el('bilan_metrics_top');
  if(bmt) bmt.innerHTML = `
    <div class="metric"><div class="metric-lbl">Investissement total</div><div class="metric-val">${fmtE(total_ttc)}</div></div>
    <div class="metric"><div class="metric-lbl">Crédit d'impôt (investisseur)</div><div class="metric-val green">${fmtE(ci_invest)}</div></div>
    <div class="metric"><div class="metric-lbl">Coût réel après CIOP</div><div class="metric-val amber">${fmtE(cout_reel)}</div></div>
    <div class="metric"><div class="metric-lbl">Revenus nets / an</div><div class="metric-val green">${fmtE(rev_net)}</div></div>
    <div class="metric"><div class="metric-lbl">Charges totales / an</div><div class="metric-val red">${fmtE(chg_total)}</div></div>
    <div class="metric"><div class="metric-lbl">Résultat net / an</div><div class="metric-val ${resultat>=0?'green':'red'}">${fmtE(resultat)}</div></div>`;
 
  const bkv = el('bilan_kv');
  if(bkv) bkv.innerHTML = `
    <div class="kv"><span class="kv-k">Revenus nets d'exploitation</span><span class="kv-v green">${fmtE(rev_net)}</span></div>
    <div class="kv"><span class="kv-k">Charges annuelles</span><span class="kv-v red">– ${fmtE(chg_total)}</span></div>
    <div class="kv"><span class="kv-k">Résultat avant crédit & financement</span><span class="kv-v ${resultat>=0?'green':'red'}">${fmtE(resultat)}</span></div>
    <div class="kv"><span class="kv-k">Crédit d'impôt / an (${etalement} ans)</span><span class="kv-v" style="color:var(--blue)">+ ${fmtE(ci_annuel)}</span></div>
    <div class="kv"><span class="kv-k">Mensualités crédit</span><span class="kv-v red">${mensualite>0?'– '+fmtE(mensualite*12):'—'}</span></div>
    <div class="kv" style="border-top:1px solid var(--border);padding-top:12px;margin-top:4px">
      <span class="kv-k" style="font-size:14px;font-weight:500">Cashflow mensuel (avec CI)</span>
      <span class="kv-v ${cf_mensuel>=0?'green':'red'}" style="font-size:20px">${fmtE(cf_mensuel)}<span style="font-size:12px;color:var(--text-dim)">/mois</span></span>
    </div>`;
 
  const bkpi = el('bilan_kpi');
  if(bkpi) bkpi.innerHTML = `
    <div class="kv"><span class="kv-k">Rendement brut</span><span class="kv-v">${fmtP(rdt_brut)}</span></div>
    <div class="kv"><span class="kv-k">Rendement net exploitation</span><span class="kv-v ${rdt_net>=5?'green':rdt_net>=3?'amber':'red'}">${fmtP(rdt_net)}</span></div>
    <div class="kv"><span class="kv-k">Rendement ajusté CIOP</span><span class="kv-v green">${fmtP(rdt_ajuste)}</span></div>
    <div class="kv"><span class="kv-k">Retour sur investissement réel</span><span class="kv-v ${payback&&payback<=12?'green':payback&&payback<=20?'amber':'red'}">${payback?fmt(payback,1)+' ans':'ND'}</span></div>
    <div class="kv"><span class="kv-k">Taux d'occupation global</span><span class="kv-v ${taux_occ>=60?'green':taux_occ>=40?'amber':'red'}">${fmtP(taux_occ)}</span></div>
    <div class="kv"><span class="kv-k">Nuits louées / an</span><span class="kv-v">${total_nuits} nuits</span></div>`;
 
  // Table 10 ans
  const bt = el('bilan_table');
  if(bt) {
    const rows = Array.from({length:10},(_,i)=>{
      const ci = i<etalement ? ci_annuel : 0;
      const flux = resultat + ci - mensualite*12;
      return {an:i+1,rev:rev_net,chg:chg_total,ci,cred:mensualite*12,flux};
    });
    bt.innerHTML = `<thead><tr>
      <th>Année</th><th class="right">Rev. nets</th><th class="right">Charges</th>
      <th class="right">Éco. CI</th><th class="right">Crédit</th><th class="right">Flux net</th>
    </tr></thead><tbody>`
    + rows.map(r=>`<tr>
      <td style="font-weight:500;color:var(--gold)">An ${r.an}</td>
      <td class="right green">${fmtE(r.rev)}</td>
      <td class="right" style="color:var(--red)">– ${fmtE(r.chg)}</td>
      <td class="right" style="color:${r.ci>0?'var(--blue)':'var(--text-dim)'}">${r.ci>0?'+ '+fmtE(r.ci):'—'}</td>
      <td class="right" style="color:${r.cred>0?'var(--red)':'var(--text-dim)'}">${r.cred>0?'– '+fmtE(r.cred):'—'}</td>
      <td class="right ${r.flux>=0?'green':'red'}">${fmtE(r.flux)}</td>
    </tr>`).join('')+'</tbody>';
  }
}
 
// Initial compute
compute();
</script>
</body>
</html>
 
